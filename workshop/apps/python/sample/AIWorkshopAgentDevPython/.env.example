# Copy this file to ".env" and fill in your own values.
# Do NOT commit the real ".env" file — it is ignored by git.

# Microsoft 365 Agents SDK connection (service principal used by the bot)
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__ANONYMOUS_ALLOWED=True

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_ENDPOINT=

# Azure AI Foundry project / agent
ENV_AZURE_DEPLOY_AI_FOUNDRY_PROJECT_ENDPOINT=
ENV_AZURE_APP_TENANT_ID=
ENV_AZURE_APP_CLIENT_ID=
ENV_AZURE_APP_CLIENT_SECRET=
ENV_FOUNDRY_AGENT_NAME=ai-knowledge-agent
ENV_FOUNDRY_AGENT_MODEL=gpt-4.1-nano

# OAuth connection name configured on the Azure Bot resource
AGENTAPPLICATION__USERAUTHORIZATION__HANDLERS__GRAPH__SETTINGS__AZUREBOTOAUTHCONNECTIONNAME=copilotCustomAuth

# Bot Framework credentials
BOT_ID=
BOT_PASSWORD=
