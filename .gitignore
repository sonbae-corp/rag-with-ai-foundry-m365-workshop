# ── Secrets & local environment files ─────────────────────────────
# Local env files with real values (keep the *.example templates)
.env
**/.env
!**/.env.example

# Microsoft 365 Agents Toolkit local / user env files
**/env/.env.local
**/env/.env.*.local
**/env/.env.*.user
**/env/.env.sandbox

# Microsoft 365 Agents Toolkit local secret configs (keep *.example)
**/.localConfigs
**/.localConfigs.playground
!**/.localConfigs.example
!**/.localConfigs.playground.example

# Workshop deploy-time generated / local secrets
# Generated from config.yaml.template at deploy time — contains tenant-specific values
workshop/templates/config.yaml
# Generated from ai-knowledge-agent.json.template — contains subscription/connection IDs
workshop/agents/ai-knowledge-agent.json
workshop/variables.local.ps1

# ── Python ────────────────────────────────────────────────────────
**/.venv/
**/.venv*/
**/venv/
**/__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
wheels/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
.python-version
pip-log.txt
pip-delete-this-directory.txt

# ── Node ──────────────────────────────────────────────────────────
**/node_modules/
**/lib/
**/dist/
**/.npm/
**/.yarn/
**/.pnp.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
*.tsbuildinfo

# ── Microsoft 365 Agents Toolkit build artifacts ──────────────────
**/appPackage/build/
**/.notification.localstore.json
**/.notification.playgroundstore.json
**/devTools/

# ── Docusaurus build output ───────────────────────────────────────
documentation/build/
documentation/.docusaurus/

# ── OS / editor noise ─────────────────────────────────────────────
.DS_Store
Thumbs.db
